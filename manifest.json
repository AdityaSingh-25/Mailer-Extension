{
  "manifest_version": 3,
  "name": "LinkedIn Helper Pro",
  "version": "2.0.0",
  "description": "Find people on LinkedIn, generate emails, send personalised messages & emails — with activity log, rate limiting and templates.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "downloads",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://mail.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "806954726600-gpo9ujtm2jl7m3h15u2n1uqg8kibf5iv.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "content_scripts": [
    {
      "js": [
        "company-formats.js",
        "content.js"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Helper Pro"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "company-formats.js",
        "popup.js"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}